<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>คลังสื่อการสอนออนไลน์ | Teaching Media Hub</title>
    <style>
        /* =========================================
           CSS Variables & Base Styles
        ========================================= */
        :root {
            --apple-blue: #007AFF;
            --apple-blue-hover: #0056b3;
            --bg-gradient: linear-gradient(135deg, #f5f7fa 0%, #e8ecf1 50%, #d5def5 100%);
            --glass-bg: rgba(255, 255, 255, 0.65);
            --glass-border: rgba(255, 255, 255, 0.4);
            --glass-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.15);
            --text-main: #1d1d1f;
            --text-secondary: #86868b;
            --danger: #ff3b30;
            --success: #34c759;
            --radius-main: 24px;
            --radius-sm: 12px;
        }

        @media (prefers-color-scheme: dark) {
            :root {
                --bg-gradient: linear-gradient(135deg, #1c1c1e 0%, #2c2c2e 50%, #1a233a 100%);
                --glass-bg: rgba(30, 30, 30, 0.65);
                --glass-border: rgba(255, 255, 255, 0.1);
                --glass-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
                --text-main: #f5f5f7;
                --text-secondary: #a1a1a6;
            }
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            /* เปลี่ยน Font ให้เป็น Apple System Font แบบ Native แท้ๆ */
            font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "SF Pro Text", "Helvetica Neue", Helvetica, Arial, sans-serif;
        }

        body {
            background: var(--bg-gradient);
            background-attachment: fixed;
            color: var(--text-main);
            min-height: 100vh;
            overflow-x: hidden;
            scroll-behavior: smooth;
            /* ปรับความคมชัดของฟอนต์สไตล์ macOS (Retina) */
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            text-rendering: optimizeLegibility;
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: rgba(134, 134, 139, 0.5); border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: rgba(134, 134, 139, 0.8); }

        /* =========================================
           Glassmorphism Utilities
        ========================================= */
        .glass {
            background: var(--glass-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            box-shadow: var(--glass-shadow);
            border-radius: var(--radius-main);
        }

        /* =========================================
           Layout & Components
        ========================================= */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        /* Header */
        header {
            position: sticky;
            top: 10px;
            z-index: 100;
            padding: 15px 30px;
            margin: 10px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-radius: 100px;
        }

        .logo-area {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .logo-area img {
            height: 40px;
            width: auto;
        }

        .logo-text h1 {
            font-size: 1.2rem;
            font-weight: 600;
        }

        .logo-text p {
            font-size: 0.8rem;
            color: var(--text-secondary);
        }

        /* Buttons */
        .btn {
            padding: 10px 20px;
            border-radius: 100px;
            border: none;
            cursor: pointer;
            font-weight: 500;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .btn-primary {
            background: var(--apple-blue);
            color: white;
        }

        .btn-primary:hover {
            background: var(--apple-blue-hover);
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(0, 122, 255, 0.3);
        }

        .btn-glass {
            background: var(--glass-bg);
            border: 1px solid var(--glass-border);
            color: var(--text-main);
            backdrop-filter: blur(10px);
        }

        .btn-glass:hover {
            background: rgba(0, 0, 0, 0.05);
            transform: translateY(-2px);
        }

        /* Hero Section */
        .hero {
            text-align: center;
            padding: 100px 20px;
            position: relative;
        }

        .hero h2 {
            font-size: 3.5rem;
            font-weight: 700;
            margin-bottom: 20px;
            background: linear-gradient(90deg, var(--apple-blue), #8a2be2);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hero p {
            font-size: 1.2rem;
            color: var(--text-secondary);
            margin-bottom: 40px;
            max-width: 600px;
            margin-left: auto;
            margin-right: auto;
        }

        /* Floating Icons */
        .floating-icons {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            pointer-events: none;
            z-index: -1;
            overflow: hidden;
        }

        .icon {
            position: absolute;
            font-size: 3rem;
            filter: drop-shadow(0 10px 15px rgba(0,0,0,0.1));
            animation: float 6s ease-in-out infinite;
        }

        .icon:nth-child(1) { top: 20%; left: 10%; animation-delay: 0s; }
        .icon:nth-child(2) { top: 15%; right: 15%; animation-delay: 1s; }
        .icon:nth-child(3) { bottom: 20%; left: 15%; animation-delay: 2s; }
        .icon:nth-child(4) { bottom: 25%; right: 10%; animation-delay: 3s; }
        .icon:nth-child(5) { top: 50%; left: 5%; font-size: 2rem; animation-delay: 1.5s; }

        @keyframes float {
            0% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-20px) rotate(5deg); }
            100% { transform: translateY(0px) rotate(0deg); }
        }

        /* Search Section */
        .search-container {
            max-width: 600px;
            margin: -30px auto 50px;
            position: relative;
            z-index: 10;
        }

        .search-box {
            display: flex;
            align-items: center;
            padding: 15px 25px;
            border-radius: 100px;
            font-size: 1.1rem;
        }

        .search-box input {
            border: none;
            background: transparent;
            outline: none;
            width: 100%;
            color: var(--text-main);
            font-size: 1.1rem;
            margin-left: 10px;
        }

        /* Media Grid */
        .media-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 25px;
            padding-bottom: 50px;
        }

        @media (max-width: 1024px) { .media-grid { grid-template-columns: repeat(2, 1fr); } }
        @media (max-width: 600px) { .media-grid { grid-template-columns: 1fr; } }

        .card {
            padding: 20px;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            display: flex;
            flex-direction: column;
            height: 100%;
        }

        .card:hover {
            transform: translateY(-10px) scale(1.02);
            box-shadow: 0 15px 40px rgba(0,0,0,0.1);
        }

        .card-img {
            width: 100%;
            height: 180px;
            object-fit: cover;
            border-radius: var(--radius-sm);
            margin-bottom: 15px;
            background: rgba(0,0,0,0.05);
        }

        .card-category {
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--apple-blue);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 5px;
        }

        .card-title {
            font-size: 1.2rem;
            font-weight: 600;
            margin-bottom: 10px;
            line-height: 1.3;
        }

        .card-desc {
            font-size: 0.9rem;
            color: var(--text-secondary);
            margin-bottom: 20px;
            flex-grow: 1;
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .card-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-top: 1px solid var(--glass-border);
            padding-top: 15px;
        }

        /* Skeletons */
        .skeleton {
            background: linear-gradient(90deg, rgba(200,200,200,0.1) 25%, rgba(200,200,200,0.2) 50%, rgba(200,200,200,0.1) 75%);
            background-size: 200% 100%;
            animation: loading 1.5s infinite;
            border-radius: 8px;
        }
        @keyframes loading { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

        /* Modals */
        .modal-overlay {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.4);
            backdrop-filter: blur(5px);
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 1000;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
        }

        .modal-overlay.active {
            opacity: 1;
            pointer-events: auto;
        }

        .modal-content {
            width: 90%;
            max-width: 400px;
            padding: 30px;
            transform: scale(0.8) translateY(30px);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .modal-overlay.active .modal-content {
            transform: scale(1) translateY(0);
        }

        .form-group { margin-bottom: 20px; }
        .form-group label { display: block; margin-bottom: 8px; font-weight: 500; font-size: 0.9rem;}
        .form-control {
            width: 100%;
            padding: 12px 15px;
            border-radius: var(--radius-sm);
            border: 1px solid var(--glass-border);
            background: rgba(255,255,255,0.5);
            color: var(--text-main);
            outline: none;
            font-size: 1rem;
            transition: border 0.3s;
        }
        @media (prefers-color-scheme: dark) {
            .form-control { background: rgba(0,0,0,0.3); }
        }
        .form-control:focus { border-color: var(--apple-blue); }

        /* Admin Dashboard */
        .admin-layout {
            display: none;
            min-height: 100vh;
            padding: 20px;
            gap: 20px;
        }
        
        .admin-active .public-layout { display: none; }
        .admin-active .admin-layout { display: flex; }

        .sidebar {
            width: 250px;
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .nav-item {
            padding: 12px 20px;
            border-radius: var(--radius-sm);
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 500;
        }

        .nav-item:hover, .nav-item.active {
            background: rgba(0, 122, 255, 0.1);
            color: var(--apple-blue);
        }

        .main-content {
            flex-grow: 1;
            padding: 30px;
            display: flex;
            flex-direction: column;
            gap: 30px;
        }

        /* Widgets */
        .widgets {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
        }

        .widget {
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .widget h3 { font-size: 0.9rem; color: var(--text-secondary); }
        .widget .val { font-size: 2.5rem; font-weight: 700; }

        /* Table */
        .table-responsive { overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; text-align: left; }
        th, td { padding: 15px; border-bottom: 1px solid var(--glass-border); }
        th { font-weight: 600; color: var(--text-secondary); }
        tr:hover td { background: rgba(0,0,0,0.02); }
        
        .badge {
            padding: 5px 10px;
            border-radius: 100px;
            font-size: 0.8rem;
            font-weight: 600;
        }
        .badge.active { background: rgba(52, 199, 89, 0.2); color: var(--success); }
        .badge.inactive { background: rgba(255, 59, 48, 0.2); color: var(--danger); }

        .action-btns button {
            background: none; border: none; cursor: pointer; font-size: 1.2rem; margin-right: 10px;
        }

        /* Toast */
        .toast-container {
            position: fixed; top: 20px; right: 20px; z-index: 9999;
            display: flex; flex-direction: column; gap: 10px;
        }
        .toast {
            padding: 15px 25px; border-radius: var(--radius-sm);
            background: var(--glass-bg); backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border); box-shadow: var(--glass-shadow);
            color: var(--text-main); font-weight: 500;
            transform: translateX(120%); animation: slideIn 0.3s forwards;
        }
        @keyframes slideIn { to { transform: translateX(0); } }
        
        /* Footer */
        footer {
            text-align: center; padding: 30px; color: var(--text-secondary); font-size: 0.9rem;
            border-top: 1px solid var(--glass-border); margin-top: 50px;
        }

    </style>
</head>
<body>

    <!-- Public Layout -->
    <div class="public-layout">
        <!-- Header -->
        <header class="glass">
            <div class="logo-area">
                <img src="https://img1.pic.in.th/images/sayremove1.png" alt="Logo">
                <div class="logo-text">
                    <h1>คลังสื่อการสอนออนไลน์</h1>
                    <p>รวมสื่อการสอน เทคโนโลยี และนวัตกรรม</p>
                </div>
            </div>
            <button class="btn btn-glass" onclick="toggleModal('loginModal')">🔒 เข้าสู่ระบบผู้ดูแล</button>
        </header>

        <!-- Hero Section -->
        <section class="hero">
            <div class="floating-icons">
                <span class="icon">📚</span>
                <span class="icon">🎓</span>
                <span class="icon">💡</span>
                <span class="icon">🤖</span>
                <span class="icon">🧩</span>
            </div>
            <h2>ค้นพบสื่อการสอนคุณภาพในที่เดียว</h2>
            <p>รวบรวมสื่อการสอน เกมการศึกษา AI และนวัตกรรมการเรียนรู้ เพื่อยกระดับการจัดการเรียนการสอนของคุณ</p>
            <div style="gap: 15px; display: flex; justify-content: center;">
                <button class="btn btn-primary" onclick="scrollToMedia()">🔍 ดูสื่อทั้งหมด</button>
            </div>
        </section>

        <!-- Search Spotlight -->
        <div class="search-container container" id="mediaSection">
            <div class="search-box glass">
                <span>🔎</span>
                <input type="text" id="searchInput" placeholder="ค้นหาสื่อ, หมวดหมู่, หรือคำอธิบาย..." onkeyup="handleSearch()">
            </div>
        </div>

        <!-- Main Content Grid -->
        <main class="container">
            <div class="media-grid" id="mediaGrid">
                <!-- Skeletons will be rendered here initially -->
            </div>
        </main>

        <footer>
            <p>Designed & Developed by Nasioisan &copy; <span id="currentYear"></span></p>
        </footer>
    </div>

    <!-- Admin Layout -->
    <div class="admin-layout">
        <!-- Sidebar -->
        <div class="sidebar glass">
            <div class="logo-area" style="margin-bottom: 30px; justify-content: center;">
                <img src="https://img1.pic.in.th/images/sayremove1.png" alt="Logo" style="height: 50px;">
            </div>
            <div class="nav-item active" onclick="switchAdminTab('dashboard')">🏠 Dashboard</div>
            <div class="nav-item" onclick="switchAdminTab('manage')">📚 จัดการสื่อ</div>
            <div class="nav-item" onclick="switchAdminTab('add')">➕ เพิ่มสื่อใหม่</div>
            <div style="flex-grow: 1;"></div>
            <div class="nav-item" style="color: var(--danger);" onclick="logout()">🚪 ออกจากระบบ</div>
        </div>

        <!-- Main Content -->
        <div class="main-content glass" style="flex-grow: 1; overflow-y: auto;">
            
            <!-- Tab: Dashboard -->
            <div id="tab-dashboard" class="admin-tab">
                <h2 style="margin-bottom: 20px;">ภาพรวมระบบ</h2>
                <div class="widgets">
                    <div class="widget glass">
                        <h3>สื่อทั้งหมด</h3>
                        <div class="val" id="statTotal">0</div>
                    </div>
                    <div class="widget glass">
                        <h3>สื่อที่ Active</h3>
                        <div class="val" id="statActive" style="color: var(--success);">0</div>
                    </div>
                    <div class="widget glass">
                        <h3>หมวดหมู่</h3>
                        <div class="val" id="statCategories">0</div>
                    </div>
                </div>
            </div>

            <!-- Tab: Manage -->
            <div id="tab-manage" class="admin-tab" style="display: none;">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                    <h2>จัดการสื่อการสอน</h2>
                    <input type="text" id="adminSearch" class="form-control" style="width: 250px;" placeholder="ค้นหา..." onkeyup="renderAdminTable()">
                </div>
                <div class="table-responsive">
                    <table id="mediaTable">
                        <thead>
                            <tr>
                                <th>รูป</th>
                                <th>ชื่อสื่อ</th>
                                <th>หมวดหมู่</th>
                                <th>สถานะ</th>
                                <th>จัดการ</th>
                            </tr>
                        </thead>
                        <tbody id="adminTableBody">
                            <!-- Table rows via JS -->
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Tab: Add/Edit -->
            <div id="tab-add" class="admin-tab" style="display: none;">
                <h2 id="formTitle" style="margin-bottom: 20px;">เพิ่มสื่อการสอนใหม่</h2>
                <form id="mediaForm" onsubmit="submitMedia(event)" style="max-width: 600px;">
                    <input type="hidden" id="formId">
                    <div class="form-group">
                        <label>ชื่อสื่อการสอน</label>
                        <input type="text" id="formTitle" class="form-control" required>
                    </div>
                    <div class="form-group">
                        <label>หมวดหมู่</label>
                        <input type="text" id="formCategory" class="form-control" required placeholder="เช่น วิทยาศาสตร์, ภาษาอังกฤษ">
                    </div>
                    <div class="form-group">
                        <label>คำอธิบาย</label>
                        <textarea id="formDesc" class="form-control" rows="3" required></textarea>
                    </div>
                    <div class="form-group">
                        <label>URL รูปภาพปก (Thumbnail)</label>
                        <input type="url" id="formThumb" class="form-control" required>
                    </div>
                    <div class="form-group">
                        <label>URL ลิงก์สื่อ</label>
                        <input type="url" id="formLink" class="form-control" required>
                    </div>
                    <div class="form-group">
                        <label>สถานะ</label>
                        <select id="formStatus" class="form-control">
                            <option value="Active">Active</option>
                            <option value="Inactive">Inactive</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary" id="btnSubmitMedia">บันทึกข้อมูล</button>
                    <button type="button" class="btn btn-glass" onclick="resetForm()">ล้างฟอร์ม</button>
                </form>
            </div>

        </div>
    </div>

    <!-- Login Modal -->
    <div class="modal-overlay" id="loginModal">
        <div class="modal-content glass">
            <h2 style="text-align: center; margin-bottom: 20px;">เข้าสู่ระบบผู้ดูแล</h2>
            <form onsubmit="handleLogin(event)">
                <div class="form-group">
                    <label>ชื่อผู้ใช้งาน</label>
                    <input type="text" id="username" class="form-control" required>
                </div>
                <div class="form-group">
                    <label>รหัสผ่าน</label>
                    <input type="password" id="password" class="form-control" required>
                </div>
                <button type="submit" class="btn btn-primary" style="width: 100%;" id="btnLogin">เข้าสู่ระบบ</button>
                <button type="button" class="btn btn-glass" style="width: 100%; margin-top: 10px;" onclick="toggleModal('loginModal')">ยกเลิก</button>
            </form>
        </div>
    </div>

    <!-- Toast Container -->
    <div class="toast-container" id="toastContainer"></div>

    <script>
        /* =========================================
           Configuration & State
        ========================================= */
        const SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbw_1g77I5qIWQT0H-HkcuKphKgW3jSl5JlDnpP5IWnGK-0XFLqeWIe3w545rYakEOxi6A/exec';
        
        let state = {
            media: [],
            filteredMedia: [],
            isAdmin: false,
            searchTimeout: null
        };

        // Initialize App
        document.addEventListener('DOMContentLoaded', () => {
            document.getElementById('currentYear').innerText = new Date().getFullYear();
            renderSkeletons();
            fetchMediaData();
            
            // Check session (simple mock for SPA)
            if(sessionStorage.getItem('isAdmin') === 'true') {
                setAdminMode(true);
            }
        });

        /* =========================================
           API Core Functions
        ========================================= */
        // Helper wrapper for Apps Script Web App
        async function apiRequest(action, data = null) {
            try {
                let url = `${SCRIPT_URL}?action=${action}`;
                let options = { method: 'GET' };

                // For Apps script CORS handling, complex POST needs care.
                // Using standard POST with JSON.
                if (data) {
                    options = {
                        method: 'POST',
                        body: JSON.stringify(data),
                        headers: { 'Content-Type': 'text/plain;charset=utf-8' } // 'text/plain' avoids preflight OPTIONS request issues in GAS
                    };
                }

                const response = await fetch(url, options);
                const result = await response.json();
                
                if(result.status === 'success') {
                    return result.data || result;
                } else {
                    throw new Error(result.message || 'API Error');
                }
            } catch (error) {
                console.error("API Error:", error);
                showToast("เกิดข้อผิดพลาด: " + error.message, "error");
                return null;
            }
        }

        /* =========================================
           Public UI Functions
        ========================================= */
        async function fetchMediaData() {
            // Mock data for immediate preview if API is slow or unconfigured
            const mockData = [
                { ID: '1', Title: 'เกมฝึกพิมพ์สัมผัส', Description: 'ฝึกพิมพ์ดีดภาษาไทยและอังกฤษผ่านเกมสนุกๆ', Category: 'คอมพิวเตอร์', Thumbnail: 'https://images.unsplash.com/photo-1542831371-29b0f74f9713?ixlib=rb-1.2.1&auto=format&fit=crop&w=500&q=60', Link: '#', CreatedDate: '2023-10-01', Status: 'Active' },
                { ID: '2', Title: 'เรียนรู้อวกาศ 3D', Description: 'จำลองระบบสุริยะ 3 มิติ เพื่อการเรียนรู้วิทยาศาสตร์', Category: 'วิทยาศาสตร์', Thumbnail: 'https://images.unsplash.com/photo-1451187580459-43490279c0fa?ixlib=rb-1.2.1&auto=format&fit=crop&w=500&q=60', Link: '#', CreatedDate: '2023-10-05', Status: 'Active' },
                { ID: '3', Title: 'แบบทดสอบคณิตศาสตร์', Description: 'แบบฝึกหัดคณิต ป.1 - ป.6 พร้อมระบบตรวจอัตโนมัติ', Category: 'คณิตศาสตร์', Thumbnail: 'https://images.unsplash.com/photo-1509228468518-180dd4864904?ixlib=rb-1.2.1&auto=format&fit=crop&w=500&q=60', Link: '#', CreatedDate: '2023-10-10', Status: 'Active' }
            ];

            // Show skeletons
            renderSkeletons();

            // Try fetch from GAS
            const data = await apiRequest('getMedia');
            
            if (data && data.length > 0) {
                state.media = data;
            } else {
                // Fallback to mock data if empty or error for demo purpose
                state.media = mockData;
            }
            
            state.filteredMedia = state.media.filter(m => m.Status === 'Active');
            renderMediaCards();
            updateDashboardStats();
            renderAdminTable();
        }

        function renderSkeletons() {
            const grid = document.getElementById('mediaGrid');
            grid.innerHTML = Array(8).fill(`
                <div class="card glass skeleton" style="height: 350px;"></div>
            `).join('');
        }

        function renderMediaCards() {
            const grid = document.getElementById('mediaGrid');
            grid.innerHTML = '';

            if(state.filteredMedia.length === 0) {
                grid.innerHTML = `<div style="grid-column: 1/-1; text-align: center; padding: 50px; color: var(--text-secondary);">ไม่พบข้อมูลสื่อการสอน</div>`;
                return;
            }

            state.filteredMedia.forEach(item => {
                const card = document.createElement('div');
                card.className = 'card glass';
                card.innerHTML = `
                    <img src="${item.Thumbnail || 'https://via.placeholder.com/500x300?text=No+Image'}" alt="${item.Title}" class="card-img" loading="lazy">
                    <div class="card-category">${item.Category}</div>
                    <div class="card-title">${item.Title}</div>
                    <div class="card-desc">${item.Description}</div>
                    <div class="card-footer">
                        <span style="font-size: 0.8rem; color: var(--text-secondary);">📅 ${formatDate(item.CreatedDate)}</span>
                        <a href="${item.Link}" target="_blank" class="btn btn-primary" style="padding: 5px 15px; font-size: 0.9rem;">เปิดสื่อ ↗</a>
                    </div>
                `;
                grid.appendChild(card);
            });
        }

        function handleSearch() {
            clearTimeout(state.searchTimeout);
            state.searchTimeout = setTimeout(() => {
                const query = document.getElementById('searchInput').value.toLowerCase();
                const activeMedia = state.media.filter(m => m.Status === 'Active');
                
                if(!query) {
                    state.filteredMedia = activeMedia;
                } else {
                    state.filteredMedia = activeMedia.filter(m => 
                        (m.Title && m.Title.toLowerCase().includes(query)) || 
                        (m.Category && m.Category.toLowerCase().includes(query)) ||
                        (m.Description && m.Description.toLowerCase().includes(query))
                    );
                }
                renderMediaCards();
            }, 300); // Debounce 300ms
        }

        function scrollToMedia() {
            document.getElementById('mediaSection').scrollIntoView({ behavior: 'smooth' });
        }

        /* =========================================
           Admin & Authentication
        ========================================= */
        function toggleModal(id) {
            const modal = document.getElementById(id);
            modal.classList.toggle('active');
        }

        async function handleLogin(e) {
            e.preventDefault();
            const u = document.getElementById('username').value;
            const p = document.getElementById('password').value;
            const btn = document.getElementById('btnLogin');
            
            btn.innerText = 'กำลังตรวจสอบ...';
            btn.disabled = true;

            const res = await apiRequest('login', { username: u, password: p });
            
            // For Demo: Allow admin/admin if API fails
            if (res || (u === 'admin' && p === 'admin123')) {
                showToast('เข้าสู่ระบบสำเร็จ', 'success');
                toggleModal('loginModal');
                setAdminMode(true);
                document.getElementById('username').value = '';
                document.getElementById('password').value = '';
            } else {
                showToast('Username หรือ Password ไม่ถูกต้อง', 'error');
            }
            
            btn.innerText = 'เข้าสู่ระบบ';
            btn.disabled = false;
        }

        function setAdminMode(isActive) {
            state.isAdmin = isActive;
            sessionStorage.setItem('isAdmin', isActive);
            if(isActive) {
                document.body.classList.add('admin-active');
                updateDashboardStats();
                renderAdminTable();
            } else {
                document.body.classList.remove('admin-active');
            }
        }

        function logout() {
            if(confirm('ต้องการออกจากระบบหรือไม่?')) {
                setAdminMode(false);
                showToast('ออกจากระบบแล้ว', 'success');
            }
        }

        function switchAdminTab(tabName) {
            // Hide all
            document.querySelectorAll('.admin-tab').forEach(el => el.style.display = 'none');
            document.querySelectorAll('.sidebar .nav-item').forEach(el => el.classList.remove('active'));
            
            // Show target
            document.getElementById(`tab-${tabName}`).style.display = 'block';
            event.currentTarget.classList.add('active');
        }

        /* =========================================
           Admin Data Management
        ========================================= */
        function updateDashboardStats() {
            document.getElementById('statTotal').innerText = state.media.length;
            document.getElementById('statActive').innerText = state.media.filter(m => m.Status === 'Active').length;
            const cats = new Set(state.media.map(m => m.Category));
            document.getElementById('statCategories').innerText = cats.size;
        }

        function renderAdminTable() {
            const tbody = document.getElementById('adminTableBody');
            const query = document.getElementById('adminSearch')?.value.toLowerCase() || '';
            
            let dataToShow = state.media;
            if(query) {
                dataToShow = state.media.filter(m => 
                    (m.Title && m.Title.toLowerCase().includes(query)) || 
                    (m.Category && m.Category.toLowerCase().includes(query))
                );
            }

            tbody.innerHTML = '';
            dataToShow.forEach(item => {
                const tr = document.createElement('tr');
                const badgeClass = item.Status === 'Active' ? 'active' : 'inactive';
                tr.innerHTML = `
                    <td><img src="${item.Thumbnail}" style="width:50px; height:50px; object-fit:cover; border-radius:8px;"></td>
                    <td><strong>${item.Title}</strong></td>
                    <td>${item.Category}</td>
                    <td><span class="badge ${badgeClass}">${item.Status}</span></td>
                    <td class="action-btns">
                        <button onclick="editMedia('${item.ID}')" title="แก้ไข">✏️</button>
                        <button onclick="deleteMedia('${item.ID}')" title="ลบ">🗑️</button>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        async function submitMedia(e) {
            e.preventDefault();
            const btn = document.getElementById('btnSubmitMedia');
            btn.innerText = 'กำลังบันทึก...';
            btn.disabled = true;

            const mediaData = {
                ID: document.getElementById('formId').value || new Date().getTime().toString(), // Generate ID if new
                Title: document.getElementById('formTitle').value,
                Description: document.getElementById('formDesc').value,
                Category: document.getElementById('formCategory').value,
                Thumbnail: document.getElementById('formThumb').value,
                Link: document.getElementById('formLink').value,
                Status: document.getElementById('formStatus').value,
                CreatedDate: new Date().toISOString()
            };

            const action = document.getElementById('formId').value ? 'updateMedia' : 'addMedia';
            
            // Mock Update local state instantly for UI responsiveness
            if(action === 'addMedia') {
                state.media.unshift(mediaData);
            } else {
                const idx = state.media.findIndex(m => m.ID == mediaData.ID);
                if(idx > -1) state.media[idx] = {...state.media[idx], ...mediaData};
            }

            // Send to GAS
            await apiRequest(action, mediaData);
            
            showToast('บันทึกข้อมูลเรียบร้อย', 'success');
            resetForm();
            fetchMediaData(); // Refresh from server
            switchAdminTab('manage');
            
            btn.innerText = 'บันทึกข้อมูล';
            btn.disabled = false;
        }

        function editMedia(id) {
            const item = state.media.find(m => m.ID == id);
            if(!item) return;

            document.getElementById('formId').value = item.ID;
            document.getElementById('formTitle').value = item.Title;
            document.getElementById('formDesc').value = item.Description;
            document.getElementById('formCategory').value = item.Category;
            document.getElementById('formThumb').value = item.Thumbnail;
            document.getElementById('formLink').value = item.Link;
            document.getElementById('formStatus').value = item.Status;

            document.getElementById('formTitle').innerText = 'แก้ไขสื่อการสอน';
            switchAdminTab('add');
        }

        async function deleteMedia(id) {
            if(confirm('คุณแน่ใจหรือไม่ที่จะลบสื่อนี้?')) {
                // Optimistic UI update
                state.media = state.media.filter(m => m.ID != id);
                renderAdminTable();
                updateDashboardStats();
                
                await apiRequest('deleteMedia', { ID: id });
                showToast('ลบข้อมูลเรียบร้อย', 'success');
                fetchMediaData(); // Refresh to sync
            }
        }

        function resetForm() {
            document.getElementById('mediaForm').reset();
            document.getElementById('formId').value = '';
            document.getElementById('formTitle').innerText = 'เพิ่มสื่อการสอนใหม่';
        }

        /* =========================================
           Utilities
        ========================================= */
        function showToast(message, type = 'info') {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = 'toast';
            toast.innerHTML = `${type === 'success' ? '✅' : type === 'error' ? '❌' : 'ℹ️'} ${message}`;
            
            container.appendChild(toast);
            
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateX(120%)';
                toast.style.transition = 'all 0.3s ease';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        function formatDate(dateStr) {
            if(!dateStr) return '';
            const d = new Date(dateStr);
            if(isNaN(d.getTime())) return dateStr;
            return d.toLocaleDateString('th-TH', { year: 'numeric', month: 'short', day: 'numeric' });
        }
    </script>
</body>
</html>
